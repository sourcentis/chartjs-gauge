{
    "name": "@sourcentis/chartjs-gauge",
    "version": "1.0.0",
    "description": "A Chart.js plugin providing a gauge chart type with needle and value label",
    "main": "dist/chartjs-gauge.umd.js",
    "module": "dist/chartjs-gauge.esm.js",
    "exports": {
        ".": {
            "import": "./dist/chartjs-gauge.esm.js",
            "require": "./dist/chartjs-gauge.umd.js"
        }
    },
    "files": [
        "dist",
        "js",
        "src"
    ],
    "scripts": {
        "build": "rollup -c rollup.config.mjs",
        "dev": "rollup -c rollup.config.mjs --watch"
    },
    "peerDependencies": {
        "chart.js": "^4.0.0"
    },
    "devDependencies": {
        "@rollup/plugin-node-resolve": "^15.0.0",
        "rollup": "^4.0.0",
        "rollup-plugin-terser": "^7.0.0"
    },
    "keywords": [
        "chart.js",
        "chartjs",
        "gauge",
        "chart",
        "plugin"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/sourcentis/chartjs-gauge.git"
    },
    "bugs": {
        "url": "https://github.com/sourcentis/chartjs-gauge/issues"
    }
}
